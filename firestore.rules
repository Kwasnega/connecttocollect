rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Technical Handshake: Verify if node is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // National Command Authority: Verify if node has administrative sovereignty
    // Prioritizes master admin email and custom claims for sub-second performance
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@company.com' ||
        request.auth.token.email == 'inspector@shlcs.com' ||
        (request.auth.token.get('email', '').lower().matches('.*admin.*')) ||
        request.auth.token.admin == true
      );
    }

    // Identity Registry: Global identity vault for personnel and clients
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      // Use write to allow both initial registration and profile updates
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Manifest Registry: Primary collection for all submitted logistics requests
    match /shipmentRequests/{shipmentRequestId} {
      // Split list logic: Admin bypass or Ownership filter
      // Note: Admins can list the entire collection; clients must use filtered queries matching their UID.
      allow list: if isAdmin();
      allow list: if isSignedIn() && (
        resource.data.requestorUid == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
      
      allow get: if isAdmin() || (isSignedIn() && (
        resource.data.requestorUid == request.auth.uid || 
        resource.data.userId == request.auth.uid
      ));
      
      // Technical Anchor: Ensure UID matches the authenticated identity during commit
      allow create: if isSignedIn() && (
        request.resource.data.requestorUid == request.auth.uid || 
        request.resource.data.userId == request.auth.uid
      );
      
      // Authority or Ownership check for updates
      allow update: if isAdmin() || (isSignedIn() && (
        resource.data.requestorUid == request.auth.uid || 
        resource.data.userId == request.auth.uid
      ));
      
      allow delete: if isAdmin();
    }

    // Intelligence Feed: Notification system for status changes
    match /notifications/{userId}/userNotifications/{notificationId} {
      allow read, update: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn();
    }

    match /adminNotifications/{notificationId} {
      allow read, update: if isAdmin();
      allow create: if isSignedIn();
    }

    // Registry Drafts: Ephemeral storage for manifest preparation
    match /shipmentDrafts/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}